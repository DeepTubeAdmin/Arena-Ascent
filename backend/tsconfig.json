{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts", "../games/**/*.ts"],
  "exclude": ["../games/**/*.tsx", "../games/**/*.test.ts"]
}
