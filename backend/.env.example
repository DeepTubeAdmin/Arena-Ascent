PORT=8787
DATABASE_URL=postgres://user:pass@localhost:5432/arena_ascent
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-long-random-string
# Chain
CHAIN=arbitrumSepolia            # arbitrumSepolia | arbitrum
RPC_URL=                         # from Alchemy
CONTRACT_ADDRESS=                # deployed ArenaAscent address
USDC_ADDRESS=                    # canonical USDC for the network
# Oracle signer — for launch a dedicated key; point contract oracle at a Safe
# and use its transaction flow for production instead of a raw key.
ORACLE_PRIVATE_KEY=
# Admin
ADMIN_ADDRESSES=0xYourWalletAddress   # comma-separated; may use admin console
FRONTEND_ORIGIN=http://localhost:5173
